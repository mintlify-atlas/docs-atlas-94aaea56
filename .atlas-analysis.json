  "keyFeatures": [
    "Asset hierarchy management with technical locations and equipment tracking",
    "Preventive and corrective maintenance (CMMS) with work orders and scheduling",
    "Budget control with cost sheet, commitments, and requisition management",
    "Multi-warehouse inventory with stock tracking and material movements",
    "Safety management with work permits, risk analysis, and PPE control",
    "Project tracking with activities, milestones, and Gantt charts",
    "Document management with version control and AI-powered search",
    "Integration with Dynamics 365, n8n automation, and MinIO storage"
  ],
